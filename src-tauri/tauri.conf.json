{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Helix",
  "version": "0.2.0",
  "identifier": "com.yoannchaudet.helix",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Helix",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 700,
        "visible": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset:; connect-src ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https://github.com https://avatars.githubusercontent.com; font-src 'self'; base-uri 'self'; form-action 'none'; frame-src 'none'; media-src 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxQ0FDNDlDOTFDQTQ2NTgKUldSWVJzcVJuTVRLNFptVGxQbnEyZ0dKSWt4ZURvcTEwTkx2NE5RbmNMOWdFLzc3ZTh6b2pvV08K",
      "endpoints": [
        "https://github.com/yoannchaudet/helix-v2/releases/latest/download/latest.json"
      ]
    }
  }
}
