{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Helix",
  "version": "0.1.0",
  "identifier": "com.yoannchaudet.helix",
  "build": {
    "frontendDist": "../src",
    "runner": "../scripts/cargo-codesign.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Helix",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 700,
        "visible": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
