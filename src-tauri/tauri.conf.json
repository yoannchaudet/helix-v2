{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Helix",
  "version": "0.1.0",
  "identifier": "com.yoannchaudet.helix",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Helix",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 700,
        "visible": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2OTc5QjY3RUZCMTVFQ0YKUldUUFhySHZaNXVYaGtTRGFtYitaRmZVMWJ1TnJsVGFqNFJuc0hKeDllbTJ6eXRDVkdaSmlXZ0MK",
      "endpoints": [
        "https://github.com/yoannchaudet/helix-v2/releases/latest/download/latest.json"
      ]
    }
  }
}
